{
  "name": "@research-hub/shared",
  "version": "1.0.0",
  "description": "Shared TypeScript types for ResearchHub",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
